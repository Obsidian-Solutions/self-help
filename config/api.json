{
  "api": {
    "external": {
      "illustrations": {
        "enabled": false,
        "name": "Undraw API",
        "endpoint": "https://api.undraw.co/api/illustrations",
        "description": "Access 1000+ illustrations (local cache used instead)",
        "documentationUrl": "https://undraw.co"
      },
      "therapists": {
        "enabled": false,
        "name": "Therapist Directory API",
        "endpoint": "https://api.example.com/therapists",
        "description": "Fetch therapist listings (optional)",
        "requiresAuth": true,
        "apiKeyVar": "THERAPIST_API_KEY"
      }
    },
    "internal": {
      "quiz": {
        "enabled": true,
        "endpoint": "/api/quiz",
        "description": "Quiz data from markdown front-matter (client-side)",
        "storage": "localStorage"
      },
      "mood": {
        "enabled": true,
        "endpoint": "/api/mood",
        "description": "Mood tracking (client-side localStorage)",
        "storage": "localStorage"
      },
      "progress": {
        "enabled": true,
        "endpoint": "/api/progress",
        "description": "Course/lesson progress tracking",
        "storage": "localStorage"
      }
    }
  },
  "authentication": {
    "provider": "client-side",
    "storage": "localStorage",
    "methods": ["email", "custom"],
    "sessionTimeout": 86400,
    "note": "No backend authentication required - all client-side"
  },
  "dataStorage": {
    "type": "localStorage",
    "persistence": true,
    "maxSize": "5MB",
    "keys": [
      "user_profile",
      "quiz_results",
      "mood_history",
      "achievements",
      "course_progress",
      "lesson_completion",
      "theme_preference"
    ]
  },
  "thirdParty": {
    "analytics": {
      "enabled": false,
      "provider": "none",
      "note": "Add Google Analytics or Plausible if needed"
    },
    "seo": {
      "enabled": true,
      "sitemap": true,
      "robotsTxt": true
    },
    "cdn": {
      "enabled": false,
      "provider": "none",
      "note": "All assets served from origin"
    }
  }
}
