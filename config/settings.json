{
  "theme": {
    "name": "MindFull",
    "version": "1.0.0",
    "author": "Your Name",
    "description": "Modern Hugo theme for mental health and self-help"
  },
  "colors": {
    "primary": "#4F46E5",
    "secondary": "#10B981",
    "accent": "#F59E0B",
    "neutral": "#374151",
    "indigo": "#6366f1",
    "purple": "#a855f7",
    "green": "#16a34a",
    "pink": "#ec4899"
  },
  "typography": {
    "fontFamily": "system-ui, -apple-system, sans-serif",
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem"
    }
  },
  "spacing": {
    "unit": "0.25rem",
    "scale": "4"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "darkMode": {
    "enabled": true,
    "selector": "[class~=\"dark\"]",
    "storageKey": "theme-preference"
  },
  "components": {
    "navbar": {
      "sticky": true,
      "showBrand": true,
      "showMenu": true,
      "showDarkToggle": true
    },
    "footer": {
      "showLinks": true,
      "showCopyright": true,
      "showSocial": false
    },
    "sidebar": {
      "enabled": true,
      "position": "right",
      "width": "300px"
    }
  },
  "animations": {
    "enabled": true,
    "duration": "300ms",
    "easing": "ease-in-out"
  }
}
