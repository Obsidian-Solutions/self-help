# Environment Variables Template
# Copy this to .env and fill in your values
# DO NOT commit .env to version control

# Site Configuration
SITE_URL=https://yourdomain.com
SITE_TITLE=MindFull - Your Mental Health Companion
SITE_DESCRIPTION=A modern mental health platform with interactive courses and self-help tools
AUTHOR_NAME=Your Name
AUTHOR_EMAIL=your.email@example.com

# Repository
REPO_URL=https://github.com/yourusername/mindfull-theme
ISSUE_URL=https://github.com/yourusername/mindfull-theme/issues

# Contact
SUPPORT_EMAIL=support@example.com
CONTACT_EMAIL=contact@example.com

# Build Configuration
BUILD_ENVIRONMENT=production
NODE_ENV=production
HUGO_ENV=production

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=
PLAUSIBLE_DOMAIN=

# API Keys (Optional)
API_KEY=
PRIVATE_API_KEY=

# Payment (Optional - if adding premium features)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Email (Optional - if adding email notifications)
SENDGRID_API_KEY=
MAILGUN_API_KEY=

# Feature Flags
FEATURE_QUIZZES=true
FEATURE_MOOD_TRACKING=true
FEATURE_ACHIEVEMENTS=true
FEATURE_DARK_MODE=true
FEATURE_JOURNAL=true
FEATURE_THERAPIST_DIRECTORY=true
FEATURE_AUTHENTICATION=false
FEATURE_PAYMENTS=false

# Third-party Services
ENABLE_COMMENTS=false
ENABLE_SEARCH=false
ENABLE_ANALYTICS=false

# Development
DEBUG_MODE=false
LOG_LEVEL=info
CACHE_ENABLED=true
MINIFY_OUTPUT=true
