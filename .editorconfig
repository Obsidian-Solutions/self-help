root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# YAML/TOML
[*.{yml,yaml,toml}]
indent_size = 2
indent_style = space

# JSON
[*.json]
indent_size = 2
indent_style = space

# JavaScript/TypeScript
[*.{js,ts,jsx,tsx}]
indent_size = 2
indent_style = space
quote_type = single

# HTML/XML
[*.{html,xml}]
indent_size = 2
indent_style = space

# CSS/SCSS
[*.{css,scss,sass,less}]
indent_size = 2
indent_style = space

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Golang (if any)
[*.go]
indent_style = tab

# Makefile
[Makefile]
indent_style = tab
